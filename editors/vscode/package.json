{
  "name": "tarn-vscode",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.6.0",
  "tarn": {
    "minVersion": "0.6.0"
  },
  "l10n": "./l10n",
  "publisher": "nazarkalytiuk",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NazarKalytiuk/hive.git"
  },
  "homepage": "https://github.com/NazarKalytiuk/hive",
  "galleryBanner": {
    "color": "#1E1B4B",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Testing"
  ],
  "keywords": [
    "tarn",
    "yaml",
    "api",
    "testing",
    "json",
    "mcp"
  ],
  "extensionDependencies": [
    "redhat.vscode-yaml"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "%capabilities.untrustedWorkspaces.description%"
    }
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:tarn",
    "onLanguage:json",
    "workspaceContains:**/*.tarn.yaml",
    "workspaceContains:**/*.tarn.yml"
  ],
  "contributes": {
    "languages": [
      {
        "id": "tarn",
        "aliases": [
          "Tarn",
          "tarn"
        ],
        "extensions": [
          ".tarn.yaml",
          ".tarn.yml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tarn",
        "scopeName": "source.tarn",
        "path": "./syntaxes/tarn.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "tarn",
        "path": "./snippets/tarn.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "tarn.runAll",
        "title": "%command.tarn.runAll.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.runFile",
        "title": "%command.tarn.runFile.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.dryRunFile",
        "title": "%command.tarn.dryRunFile.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.validateFile",
        "title": "%command.tarn.validateFile.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.rerunLast",
        "title": "%command.tarn.rerunLast.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.runFailed",
        "title": "%command.tarn.runFailed.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.selectEnvironment",
        "title": "%command.tarn.selectEnvironment.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.setTagFilter",
        "title": "%command.tarn.setTagFilter.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.clearTagFilter",
        "title": "%command.tarn.clearTagFilter.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.showOutput",
        "title": "%command.tarn.showOutput.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.installTarn",
        "title": "%command.tarn.installTarn.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.runTestFromCodeLens",
        "title": "%command.tarn.runTestFromCodeLens.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.dryRunTestFromCodeLens",
        "title": "%command.tarn.dryRunTestFromCodeLens.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.exportCurl",
        "title": "%command.tarn.exportCurl.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.clearHistory",
        "title": "%command.tarn.clearHistory.title%",
        "category": "%command.category%",
        "icon": "$(trash)"
      },
      {
        "command": "tarn.showWalkthrough",
        "title": "%command.tarn.showWalkthrough.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.initProject",
        "title": "%command.tarn.initProject.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.refreshDiscovery",
        "title": "%command.tarn.refreshDiscovery.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.reloadEnvironments",
        "title": "%command.tarn.reloadEnvironments.title%",
        "category": "%command.category%",
        "icon": "$(refresh)"
      },
      {
        "command": "tarn.setEnvironmentFromTree",
        "title": "%command.tarn.setEnvironmentFromTree.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.openEnvironmentSource",
        "title": "%command.tarn.openEnvironmentSource.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.copyEnvironmentAsFlag",
        "title": "%command.tarn.copyEnvironmentAsFlag.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.showStepDetails",
        "title": "%command.tarn.showStepDetails.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.copyCaptureValue",
        "title": "%command.tarn.copyCaptureValue.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.toggleHideCaptures",
        "title": "%command.tarn.toggleHideCaptures.title%",
        "category": "%command.category%",
        "icon": "$(eye-closed)"
      },
      {
        "command": "tarn.jumpToFailure",
        "title": "%command.tarn.jumpToFailure.title%",
        "category": "%command.category%"
      },
      {
        "command": "tarn.openHtmlReport",
        "title": "%command.tarn.openHtmlReport.title%",
        "category": "%command.category%",
        "icon": "$(graph)"
      },
      {
        "command": "tarn.benchStep",
        "title": "%command.tarn.benchStep.title%",
        "category": "%command.category%",
        "icon": "$(dashboard)"
      },
      {
        "command": "tarn.importHurl",
        "title": "%command.tarn.importHurl.title%",
        "category": "%command.category%",
        "icon": "$(arrow-down)"
      },
      {
        "command": "tarn.pinHistoryEntry",
        "title": "%command.tarn.pinHistoryEntry.title%",
        "category": "%command.category%",
        "icon": "$(pin)"
      },
      {
        "command": "tarn.unpinHistoryEntry",
        "title": "%command.tarn.unpinHistoryEntry.title%",
        "category": "%command.category%",
        "icon": "$(pinned)"
      },
      {
        "command": "tarn.rerunFromHistory",
        "title": "%command.tarn.rerunFromHistory.title%",
        "category": "%command.category%",
        "icon": "$(debug-rerun)"
      },
      {
        "command": "tarn.filterHistory",
        "title": "%command.tarn.filterHistory.title%",
        "category": "%command.category%",
        "icon": "$(filter)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tarn",
          "title": "%viewsContainers.tarn.title%",
          "icon": "media/tarn-icon.svg"
        }
      ]
    },
    "views": {
      "tarn": [
        {
          "id": "tarn.environments",
          "name": "%views.tarn.environments.name%",
          "icon": "$(symbol-variable)",
          "contextualTitle": "%views.tarn.environments.contextualTitle%"
        },
        {
          "id": "tarn.runHistory",
          "name": "%views.tarn.runHistory.name%",
          "icon": "$(history)",
          "contextualTitle": "%views.tarn.runHistory.contextualTitle%"
        },
        {
          "id": "tarn.captures",
          "name": "%views.tarn.captures.name%",
          "icon": "$(list-tree)",
          "contextualTitle": "%views.tarn.captures.contextualTitle%"
        },
        {
          "id": "tarn.fixPlan",
          "name": "%views.tarn.fixPlan.name%",
          "icon": "$(lightbulb)",
          "contextualTitle": "%views.tarn.fixPlan.contextualTitle%"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "tarn.gettingStarted",
        "title": "%walkthrough.gettingStarted.title%",
        "description": "%walkthrough.gettingStarted.description%",
        "steps": [
          {
            "id": "tarn.install",
            "title": "%walkthrough.step.install.title%",
            "description": "%walkthrough.step.install.description%",
            "media": {
              "markdown": "media/walkthrough/install.md"
            }
          },
          {
            "id": "tarn.openExample",
            "title": "%walkthrough.step.openExample.title%",
            "description": "%walkthrough.step.openExample.description%",
            "media": {
              "markdown": "media/walkthrough/example.md"
            }
          },
          {
            "id": "tarn.runFirst",
            "title": "%walkthrough.step.runFirst.title%",
            "description": "%walkthrough.step.runFirst.description%",
            "media": {
              "markdown": "media/walkthrough/run.md"
            }
          },
          {
            "id": "tarn.pickEnv",
            "title": "%walkthrough.step.pickEnv.title%",
            "description": "%walkthrough.step.pickEnv.description%",
            "media": {
              "markdown": "media/walkthrough/env.md"
            }
          },
          {
            "id": "tarn.inspectFailure",
            "title": "%walkthrough.step.inspectFailure.title%",
            "description": "%walkthrough.step.inspectFailure.description%",
            "media": {
              "markdown": "media/walkthrough/failure.md"
            }
          }
        ]
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "tarn.runTestFromCodeLens",
          "when": "false"
        },
        {
          "command": "tarn.dryRunTestFromCodeLens",
          "when": "false"
        },
        {
          "command": "tarn.setEnvironmentFromTree",
          "when": "false"
        },
        {
          "command": "tarn.openEnvironmentSource",
          "when": "false"
        },
        {
          "command": "tarn.copyEnvironmentAsFlag",
          "when": "false"
        },
        {
          "command": "tarn.showStepDetails",
          "when": "false"
        },
        {
          "command": "tarn.copyCaptureValue",
          "when": "false"
        },
        {
          "command": "tarn.jumpToFailure",
          "when": "false"
        },
        {
          "command": "tarn.pinHistoryEntry",
          "when": "false"
        },
        {
          "command": "tarn.unpinHistoryEntry",
          "when": "false"
        },
        {
          "command": "tarn.rerunFromHistory",
          "when": "false"
        },
        {
          "command": "tarn.runFile",
          "when": "resourceLangId == tarn"
        },
        {
          "command": "tarn.dryRunFile",
          "when": "resourceLangId == tarn"
        },
        {
          "command": "tarn.validateFile",
          "when": "resourceLangId == tarn"
        },
        {
          "command": "tarn.exportCurl",
          "when": "resourceLangId == tarn"
        },
        {
          "command": "tarn.openHtmlReport",
          "when": "resourceLangId == tarn"
        },
        {
          "command": "tarn.benchStep",
          "when": "resourceLangId == tarn"
        }
      ],
      "editor/title/run": [
        {
          "command": "tarn.runFile",
          "when": "resourceLangId == tarn",
          "group": "navigation@1"
        },
        {
          "command": "tarn.dryRunFile",
          "when": "resourceLangId == tarn",
          "group": "navigation@2"
        }
      ],
      "view/title": [
        {
          "command": "tarn.filterHistory",
          "when": "view == tarn.runHistory",
          "group": "navigation@1"
        },
        {
          "command": "tarn.clearHistory",
          "when": "view == tarn.runHistory",
          "group": "navigation@2"
        },
        {
          "command": "tarn.reloadEnvironments",
          "when": "view == tarn.environments",
          "group": "navigation"
        },
        {
          "command": "tarn.toggleHideCaptures",
          "when": "view == tarn.captures",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "tarn.openEnvironmentSource",
          "when": "view == tarn.environments && viewItem =~ /^tarnEnvEntry/",
          "group": "inline"
        },
        {
          "command": "tarn.copyEnvironmentAsFlag",
          "when": "view == tarn.environments && viewItem =~ /^tarnEnvEntry/",
          "group": "inline"
        },
        {
          "command": "tarn.rerunFromHistory",
          "when": "view == tarn.runHistory && viewItem =~ /^tarnRunEntry/",
          "group": "inline@1"
        },
        {
          "command": "tarn.pinHistoryEntry",
          "when": "view == tarn.runHistory && viewItem == tarnRunEntry",
          "group": "inline@2"
        },
        {
          "command": "tarn.unpinHistoryEntry",
          "when": "view == tarn.runHistory && viewItem == tarnRunEntryPinned",
          "group": "inline@2"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "tarn.binaryPath": {
          "type": "string",
          "default": "tarn",
          "description": "%configuration.tarn.binaryPath.description%",
          "scope": "machine-overridable"
        },
        "tarn.lspBinaryPath": {
          "type": "string",
          "default": "tarn-lsp",
          "description": "%configuration.tarn.lspBinaryPath.description%",
          "scope": "machine-overridable"
        },
        "tarn.experimentalLspClient": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.tarn.experimentalLspClient.description%",
          "scope": "window"
        },
        "tarn.testFileGlob": {
          "type": "string",
          "default": "**/*.tarn.yaml",
          "description": "%configuration.tarn.testFileGlob.description%",
          "scope": "resource"
        },
        "tarn.excludeGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/target/**",
            "**/node_modules/**",
            "**/.git/**"
          ],
          "description": "%configuration.tarn.excludeGlobs.description%",
          "scope": "resource"
        },
        "tarn.defaultEnvironment": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "%configuration.tarn.defaultEnvironment.description%",
          "scope": "resource"
        },
        "tarn.defaultTags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%configuration.tarn.defaultTags.description%",
          "scope": "resource"
        },
        "tarn.parallel": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.tarn.parallel.description%",
          "scope": "resource"
        },
        "tarn.jsonMode": {
          "type": "string",
          "enum": [
            "verbose",
            "compact"
          ],
          "default": "verbose",
          "description": "%configuration.tarn.jsonMode.description%",
          "scope": "resource"
        },
        "tarn.requestTimeoutMs": {
          "type": "number",
          "default": 120000,
          "description": "%configuration.tarn.requestTimeoutMs.description%",
          "scope": "machine-overridable"
        },
        "tarn.showCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.tarn.showCodeLens.description%",
          "scope": "resource"
        },
        "tarn.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.tarn.statusBar.enabled.description%",
          "scope": "resource"
        },
        "tarn.validateOnSave": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.tarn.validateOnSave.description%",
          "scope": "resource"
        },
        "tarn.notifications.failure": {
          "type": "string",
          "enum": [
            "always",
            "focused",
            "off"
          ],
          "enumDescriptions": [
            "%configuration.tarn.notifications.failure.enum.always%",
            "%configuration.tarn.notifications.failure.enum.focused%",
            "%configuration.tarn.notifications.failure.enum.off%"
          ],
          "default": "focused",
          "description": "%configuration.tarn.notifications.failure.description%",
          "scope": "resource"
        },
        "tarn.cookieJarMode": {
          "type": "string",
          "enum": [
            "default",
            "per-test"
          ],
          "enumDescriptions": [
            "%configuration.tarn.cookieJarMode.enum.default%",
            "%configuration.tarn.cookieJarMode.enum.per-test%"
          ],
          "default": "default",
          "description": "%configuration.tarn.cookieJarMode.description%",
          "scope": "resource"
        }
      }
    },
    "configurationDefaults": {
      "files.associations": {
        "*.tarn.yaml": "tarn",
        "*.tarn.yml": "tarn"
      },
      "[tarn]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2
      },
      "yaml.schemas": {
        "https://raw.githubusercontent.com/NazarKalytiuk/hive/main/schemas/v1/testfile.json": [
          "*.tarn.yaml",
          "*.tarn.yml"
        ]
      },
      "json.schemas": [
        {
          "fileMatch": [
            "tarn-report.json",
            "*.tarn-report.json"
          ],
          "url": "https://raw.githubusercontent.com/NazarKalytiuk/hive/main/schemas/v1/report.json"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "pretest:integration": "tsc -p tests/integration/tsconfig.json && npm run build",
    "test:integration": "node tests/integration/out/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "glob": "^10.3.10",
    "mocha": "^10.3.0",
    "ovsx": "^0.10.10",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "yaml": "^2.4.0",
    "zod": "^3.22.0"
  }
}
